{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "outDir": "dist-electron",
    "rootDirs": ["electron", "shared"],
    "types": ["node"]
  },
  "include": ["electron", "shared"]
}
